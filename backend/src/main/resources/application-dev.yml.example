spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://wgxhl.space:3306/recipe?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: recipe
    password: 123456

cos:
  secret-id: ${COS_SECRET_ID:your-secret-id}
  secret-key: ${COS_SECRET_KEY:your-secret-key}
  region: ${COS_REGION:ap-guangzhou}
  bucket: ${COS_BUCKET:your-bucket-name}
  base-url: ${COS_BASE_URL:https://your-bucket-name.cos.ap-guangzhou.myqcloud.com}

push:
  vapid:
    public-key: ${PUSH_VAPID_PUBLIC_KEY:}
    private-key: ${PUSH_VAPID_PRIVATE_KEY:}
    subject: ${PUSH_VAPID_SUBJECT:mailto:admin@wgxhl.space}
