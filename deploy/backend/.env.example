APP_PORT=9001

SPRING_DATASOURCE_URL=jdbc:mysql://your-mysql-host:3306/recipe?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=recipe
SPRING_DATASOURCE_PASSWORD=your-password

COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_REGION=ap-chengdu
COS_BUCKET=your-bucket
COS_BASE_URL=https://your-image-domain.example.com

# Generate once and keep this pair stable. Existing browser subscriptions depend on it.
# backend: java -cp "target/classes;$(cat target/classpath.txt)" nl.martijndwars.webpush.cli.Cli generate-key
PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key
PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key
PUSH_VAPID_SUBJECT=mailto:admin@wgxhl.space
PUSH_TTL_SECONDS=604800
